{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src/**/*", "extension/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "extension/**/*.test.ts"]
}
